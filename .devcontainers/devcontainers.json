{
    "name": "WiByte Logic Lab",
    "image": "mcr.microsoft.com/devcontainers/python:3.11",
    "features": {
        "ghcr.io/devcontainers/features/desktop-lite:1": {
            "version": "latest"
        }
    },
    "forwardPorts": [6080],
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",      // Adds the "Play" button for Class 1
                "ms-python.vscode-pylance", // This is the "Brain" of the Python extension
                "github.copilot",        // Power for the Tutor
                "github.copilot-chat"    // The Tutor sidebar
                "extensions.ignoreRecommendations": true
            ],
            "settings": {
                // --- 1. LAYOUT: REPLIT-STYLE VERTICAL STACK ---
                "workbench.panel.defaultLocation": "right", 
                "workbench.panel.alignment": "justify",     // Makes the terminal span the height
                "workbench.activityBar.location": "hidden", // Extra horizontal space
                
                // --- 2. PEDAGOGY: PROTECTING THE "LOGIC MUSCLE" ---
                // Disables Ghost-writing (Autocomplete)
                "editor.inlineSuggest.enabled": false,
                "github.copilot.editor.enableAutoCompletions": false,
                "github.copilot.inlineSuggest.enable": false,
                
                // Disables "Keep/Undo" popups and Inline AI editing
                "github.copilot.editor.enableCodeActions": false,
                "github.copilot.chat.editor.enableCodeActions": false,
                "github.copilot.editor.enableInlineChat": false,

                // 1. KILL THE "GENERATE" FLOATING BUTTON
                "github.copilot.editor.enableAutoCompletions": false,
                "github.copilot.editor.enableCodeActions": false,
                "github.copilot.editor.enableInlineChat": false, // This usually stops the shortcut
    
                // 2. THE "GHOST" PROMPT IN EMPTY FILES
                // This stops the "Press Ctrl+I to generate" text appearing in new files
                "github.copilot.editor.showInlayHints": false,
                "github.copilot.chat.editor.temporaryHints": false,

                // 3. FORCE THE SIDEBAR ONLY
                // This tells the AI it is NOT allowed to edit the document directly
                "github.copilot.chat.editor.enableCodeActions": false,
                "github.copilot.chat.runCommand.enabled": false



                
                // --- 3. PERFORMANCE: "VANILLA" SPEED ---
                "python.analysis.indexing": false, // Stops background library scanning
                "chat.mcp.autostart": "never",     // Prevents the "Chat is almost ready" hang
                "github.copilot.chat.localIndex.enabled": false // Faster startup
            }
        }
    }
}
